# Copy to .env and adjust. Dev defaults point at the bundled cluster (.devdb).
NODE_ENV=development
PORT=3333

# Bundled dev Postgres (unix socket in /tmp, port 5433, trust auth, user "kanni")
DATABASE_URL=postgresql://kanni@localhost/kanni_dev?host=/tmp&port=5433

JWT_SECRET=dev-change-me-in-prod
JWT_EXPIRES_IN=30d

# OTP: in dev the code is returned in the API response and logged.
# In prod set OTP_PROVIDER=msg91 and add the credentials.
OTP_PROVIDER=dev
OTP_TTL_SECONDS=300

# Payments: 'mock' (default, deterministic, no network) or 'razorpay'.
# For razorpay set the keys; payouts also need a RazorpayX account number.
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAYX_ACCOUNT=
RAZORPAY_WEBHOOK_SECRET=
